{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "globeiron/cta",
  "version": "1.0.0",
  "title": "Call to Action",
  "category": "globeiron",
  "icon": "megaphone",
  "description": "Prominent call-to-action section.",
  "keywords": ["cta", "call to action", "promo"],
  "textdomain": "globeiron",
  "attributes": {
    "heading":     { "type": "string", "default": "Ready to get started?" },
    "body":        { "type": "string", "default": "Join thousands of teams building with Globeiron." },
    "buttonLabel": { "type": "string", "default": "Get Started" },
    "buttonUrl":   { "type": "string", "default": "#" }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  }
}
